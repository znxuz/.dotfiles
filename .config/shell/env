append_path() {
	case ":$PATH:" in
		*:"$1":*)
			;;
		*)
			PATH="${PATH:+$PATH:}$1"
	esac
}
man() {
	LESS_TERMCAP_mb=$(tput bold; tput setaf 1) \
	LESS_TERMCAP_md=$(tput bold; tput setaf 1) \
	LESS_TERMCAP_me=$(tput sgr0) \
	LESS_TERMCAP_ue=$(tput sgr0) \
	LESS_TERMCAP_us=$(tput smul; tput bold; tput setaf 2) \
	LESS_TERMCAP_mr=$(tput rev) \
	LESS_TERMCAP_mh=$(tput dim) \
	LESS_TERMCAP_ZN=$(tput ssubm) \
	LESS_TERMCAP_ZV=$(tput rsubm) \
	LESS_TERMCAP_ZO=$(tput ssupm) \
	LESS_TERMCAP_ZW=$(tput rsupm) \
	LESS_TERMCAP_se=$(tput sgr0) \
	LESS_TERMCAP_so=$(tput bold; tput setaf 0; tput setab 7) \
	GROFF_NO_SGR=1 \
	PAGER='less --incsearch' \
	command man "$@"
}

append_path $(find $HOME/.local/bin -type d | tr '\n' ':' | sed 's/:$//')

